{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --worker-class gevent --workers 1 --threads 4",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
